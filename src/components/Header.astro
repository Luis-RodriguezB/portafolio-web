---
import { getTranslations } from "../utils/i18n";

const t = getTranslations(Astro.url);
const isES = Astro.url.pathname.startsWith("/es");
---

<header class="fixed top-0 left-0 right-0 z-50">
  <div
    class="max-w-7xl mx-auto px-6 py-6 flex items-center justify-end md:justify-between"
  >
    <div class="flex-1"></div>
    <nav class="hidden md:block">
      <ul
        class="flex items-center gap-20 font-semibold text-gray-800 dark:text-slate-200"
      >
        <li>
          <a href="#home" class="hover:text-cyan-500 dark:hover:text-cyan-400"
            >{t.header.home}</a
          >
        </li>
        <li>
          <a
            href="#experience"
            class="hover:text-cyan-500 dark:hover:text-cyan-400"
            >{t.header.experience}</a
          >
        </li>
        <li>
          <a
            href="#contact"
            class="hover:text-cyan-500 dark:hover:text-cyan-400"
            >{t.header.contact}</a
          >
        </li>
      </ul>
    </nav>

    <div class="hidden md:flex flex-1 justify-end items-center gap-4">
      <!-- Theme toggle (desktop) -->
      <button
        class="theme-toggle-btn p-1 rounded-lg text-gray-700 dark:text-slate-200 hover:text-cyan-500 dark:hover:text-cyan-400 transition-colors"
        aria-label={t.header["theme-toggle"]}
      >
        <!-- Moon: visible in light mode -->
        <svg
          class="w-5 h-5 block dark:hidden"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"
          ></path>
        </svg>
        <!-- Sun: visible in dark mode -->
        <svg
          class="w-5 h-5 hidden dark:block"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 2.25a.75.75 0 0 1 .75.75v2.25a.75.75 0 0 1-1.5 0V3a.75.75 0 0 1 .75-.75ZM7.5 12a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0ZM18.894 6.166a.75.75 0 0 0-1.06-1.06l-1.591 1.59a.75.75 0 1 0 1.06 1.061l1.591-1.59ZM21.75 12a.75.75 0 0 1-.75.75h-2.25a.75.75 0 0 1 0-1.5H21a.75.75 0 0 1 .75.75ZM17.834 18.894a.75.75 0 0 0 1.06-1.06l-1.59-1.591a.75.75 0 1 0-1.061 1.06l1.59 1.591ZM12 18a.75.75 0 0 1 .75.75V21a.75.75 0 0 1-1.5 0v-2.25A.75.75 0 0 1 12 18ZM7.166 17.834a.75.75 0 0 0-1.06 1.06l1.59 1.591a.75.75 0 1 0 1.061-1.06l-1.59-1.591ZM6 12a.75.75 0 0 1-.75.75H3a.75.75 0 0 1 0-1.5h2.25A.75.75 0 0 1 6 12ZM6.166 6.106a.75.75 0 0 0 1.06 1.06l1.591-1.59a.75.75 0 1 0-1.06-1.061L6.166 6.106Z"
          ></path>
        </svg>
      </button>

      <div class="flex gap-2">
        <a href="/" class={isES ? "font-normal" : "font-bold"}>EN</a> |
        <a href="/es" class={isES ? "font-bold" : "font-normal"}>ES</a>
      </div>
    </div>

    <!-- Mobile controls -->
    <div class="md:hidden flex items-center gap-3">
      <!-- Theme toggle (mobile) -->
      <button
        class="theme-toggle-btn p-1 rounded-lg text-gray-700 dark:text-slate-200 hover:text-cyan-500 dark:hover:text-cyan-400 transition-colors"
        aria-label={t.header["theme-toggle"]}
      >
        <svg
          class="w-5 h-5 block dark:hidden"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"
          ></path>
        </svg>
        <svg
          class="w-5 h-5 hidden dark:block"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 2.25a.75.75 0 0 1 .75.75v2.25a.75.75 0 0 1-1.5 0V3a.75.75 0 0 1 .75-.75ZM7.5 12a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0ZM18.894 6.166a.75.75 0 0 0-1.06-1.06l-1.591 1.59a.75.75 0 1 0 1.06 1.061l1.591-1.59ZM21.75 12a.75.75 0 0 1-.75.75h-2.25a.75.75 0 0 1 0-1.5H21a.75.75 0 0 1 .75.75ZM17.834 18.894a.75.75 0 0 0 1.06-1.06l-1.59-1.591a.75.75 0 1 0-1.061 1.06l1.59 1.591ZM12 18a.75.75 0 0 1 .75.75V21a.75.75 0 0 1-1.5 0v-2.25A.75.75 0 0 1 12 18ZM7.166 17.834a.75.75 0 0 0-1.06 1.06l1.59 1.591a.75.75 0 1 0 1.061-1.06l-1.59-1.591ZM6 12a.75.75 0 0 1-.75.75H3a.75.75 0 0 1 0-1.5h2.25A.75.75 0 0 1 6 12ZM6.166 6.106a.75.75 0 0 0 1.06 1.06l1.591-1.59a.75.75 0 1 0-1.06-1.061L6.166 6.106Z"
          ></path>
        </svg>
      </button>

      <button
        id="menu-btn"
        class="text-gray-700 dark:text-slate-200 focus:outline-none"
        aria-label={t.header["menu-btn"]}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-7 w-7"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="md:hidden hidden">
    <ul
      class="flex flex-col items-center gap-6 font-semibold text-gray-800 dark:text-slate-200"
    >
      <li><a href="#home">{t.header.home}</a></li>
      <li><a href="#experience">{t.header.experience}</a></li>
      <li><a href="#contact">{t.header.contact}</a></li>
    </ul>
  </nav>

  <div id="mobile-lang" class="hidden md:hidden py-6">
    <div class="flex justify-center gap-2">
      <a href="/" class={isES ? "font-normal" : "font-bold"}>EN</a> |
      <a href="/es" class={isES ? "font-bold" : "font-normal"}>ES</a>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const btn = document.getElementById("menu-btn");
  const menu = document.getElementById("mobile-menu");
  const lang = document.getElementById("mobile-lang");

  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    lang?.classList.toggle("hidden");
  });

  // Theme toggle
  function toggleTheme() {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  }

  document.querySelectorAll(".theme-toggle-btn").forEach((btn) => {
    btn.addEventListener("click", toggleTheme);
  });
</script>
