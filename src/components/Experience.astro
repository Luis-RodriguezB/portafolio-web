---
import { getTranslations } from "../utils/i18n";

const lang = Astro.url.pathname.startsWith("/es") ? "es" : "en";
const t = getTranslations(Astro.url);
const experiences = t.experience.experiences;
---

<section id="experience">
  <div class="py-24 w-full">
    <h2 class="text-3xl font-bold mb-10 text-gray-900 dark:text-white">
      {t.experience.title}
    </h2>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div
        class="absolute left-3 top-2 bottom-2 w-0.5 hidden sm:block"
        style="background: linear-gradient(to bottom, var(--accent), transparent); opacity: 0.4;"
      ></div>

      <div class="space-y-8">
        {
          experiences.map((exp) => (
            <div class="relative sm:pl-12">
              <!-- Timeline dot -->
              <div
                class="absolute left-0 top-6 w-6 h-6 rounded-full border-2 hidden sm:flex items-center justify-center"
                style="background: var(--card-bg); border-color: var(--accent);"
              >
                <div class="w-2 h-2 rounded-full" style="background: var(--accent);"></div>
              </div>

              <!-- Card -->
              <div class="card p-6 hover:shadow-lg" style="border-left: 3px solid var(--accent);">
                <!-- Header row -->
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
                  <div>
                    <h3 class="text-lg font-bold text-gray-900 dark:text-white">
                      {exp.role}
                    </h3>
                    <p class="text-sm font-medium" style="color: var(--accent)">
                      {lang === "es" ? "en" : "at"} {exp.company}
                    </p>
                  </div>
                  <span
                    class="font-mono text-xs px-3 py-1 rounded-full border whitespace-nowrap self-start sm:self-auto"
                    style="color: var(--muted); border-color: var(--card-border); background: var(--code-bg);"
                  >
                    {exp.date}
                  </span>
                </div>

                <!-- Description -->
                <p class="text-sm leading-relaxed mb-4" style="color: var(--muted)">
                  {exp.description}
                </p>

                <!-- Tech tags -->
                {exp.tags && exp.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {exp.tags.map((tag: string) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
