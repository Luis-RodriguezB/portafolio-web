---
import { getTranslations } from "../utils/i18n";

const t = getTranslations(Astro.url);
---

<section id="contact">
  <div class="py-24 w-full">
    <h2 class="text-3xl font-bold mb-4 text-gray-900 dark:text-white">
      {t.contact.title}
    </h2>

    <p class="text-base mb-10 max-w-xl" style="color: var(--muted)">
      {t.contact.description}
    </p>

    <!-- Contact cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <!-- LinkedIn -->
      <a
        href="https://www.linkedin.com/in/luisrb05/"
        target="_blank"
        rel="noopener noreferrer"
        class="card group p-5 flex items-center gap-4 hover:border-(--accent) transition-all duration-200 hover:shadow-md"
      >
        <div
          class="w-11 h-11 rounded-xl flex items-center justify-center shrink-0 transition-colors"
          style="background: var(--code-bg);"
        >
          <!-- LinkedIn icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5 transition-colors group-hover:text-(--accent)"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
        </div>
        <div class="min-w-0">
          <p
            class="font-semibold text-sm text-gray-800 dark:text-slate-200 group-hover:text-(--accent) transition-colors"
          >
            LinkedIn
          </p>
          <p class="text-xs truncate" style="color: var(--muted)">
            linkedin.com/in/luisrb05
          </p>
        </div>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 ml-auto shrink-0 opacity-40 group-hover:opacity-100 group-hover:text-(--accent) transition-all"
          style="fill: none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
          ></path>
        </svg>
      </a>

      <!-- Email -->
      <a
        href="mailto:lrodriguezbaltodano97@gmail.com"
        class="card group p-5 flex items-center gap-4 hover:border-(--accent) transition-all duration-200 hover:shadow-md"
      >
        <div
          class="w-11 h-11 rounded-xl flex items-center justify-center shrink-0 transition-colors"
          style="background: var(--code-bg);"
        >
          <!-- Envelope icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5 transition-colors group-hover:text-(--accent)"
            style="fill: none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path>
          </svg>
        </div>
        <div class="min-w-0">
          <p
            class="font-semibold text-sm text-gray-800 dark:text-slate-200 group-hover:text-(--accent) transition-colors"
          >
            Email
          </p>
          <p class="text-xs truncate" style="color: var(--muted)">
            lrodriguezbaltodano97@gmail.com
          </p>
        </div>
      </a>

      <!-- GitHub -->
      <a
        href="https://github.com/Luis-RodriguezB"
        target="_blank"
        rel="noopener noreferrer"
        class="card group p-5 flex items-center gap-4 hover:border-(--accent) transition-all duration-200 hover:shadow-md"
      >
        <div
          class="w-11 h-11 rounded-xl flex items-center justify-center shrink-0 transition-colors"
          style="background: var(--code-bg);"
        >
          <!-- GitHub icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5 transition-colors group-hover:text-(--accent)"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
            ></path>
          </svg>
        </div>
        <div class="min-w-0">
          <p
            class="font-semibold text-sm text-gray-800 dark:text-slate-200 group-hover:text-(--accent) transition-colors"
          >
            GitHub
          </p>
          <p class="text-xs truncate" style="color: var(--muted)">
            github.com/Luis-RodriguezB
          </p>
        </div>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 ml-auto shrink-0 opacity-40 group-hover:opacity-100 group-hover:text-(--accent) transition-all"
          style="fill: none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
          ></path>
        </svg>
      </a>
    </div>
  </div>
</section>
